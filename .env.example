# ─────────────────────────────────────────────
#  Quiz Platform – Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Flask secret key (generate one with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-key-change-this-in-production

# MongoDB Atlas Connection String
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/quizdb

# JWT Secret (can be same as SECRET_KEY or different)
JWT_SECRET=your-jwt-secret-key-change-this

# Environment (development / production)
FLASK_ENV=development

# Port (Render uses PORT env var automatically)
PORT=5000
